# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/pets_marketplace

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Admin seed credentials (used by npm run seed)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@petnest.com
ADMIN_PASSWORD=Admin@12345

# Contact info (used to seed / expose site settings)
WHATSAPP_NUMBER=919999999999
PHONE_NUMBER=+919999999999

# Google Sheets live sync (optional)
# See server/scripts/google-sheets-appscript.gs
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_URL=

# Resend transactional email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=My Duke <no-reply@yourdomain.com>
ADMIN_NOTIFY_EMAIL=admin@petnest.com
SITE_NAME=My Duke
